{
  "name": "performos-backend",
  "build": {
    "type": "python",
    "buildCommand": "pip install -r requirements.txt"
  },
  "run": {
    "command": "uvicorn server:app --host 0.0.0.0 --port ${PORT:-8001}"
  },
  "env": {
    "MONGO_URL": "${MONGO_URL}",
    "DB_NAME": "${DB_NAME}",
    "JWT_SECRET": "${JWT_SECRET}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}"
  }
}